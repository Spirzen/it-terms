---
import path from 'node:path';
import {findRepoRoot} from '@/lib/ecosystem.mjs';
import {loadGlossaryPages} from '@/lib/glossary/load-glossary.mjs';
import {getPortalContext} from '@/lib/portal.mjs';
import GlossarySearch from '@/components/GlossarySearch.astro';
import PortalLayout from '@/components/PortalLayout.astro';
import PortalSidebar from '@/components/PortalSidebar.astro';

export async function getStaticPaths() {
  const contentDir = path.join(findRepoRoot(), 'content/glossary');
  const glossary = await loadGlossaryPages(contentDir);
  const paths = [];
  const totalTerms = glossary.letters.reduce((sum, page) => sum + page.termCount, 0);

  if (glossary.intro) {
    paths.push({
      params: {slug: 'intro'},
      props: {
        page: glossary.intro,
        sidebar: glossary.sidebar,
        kind: 'intro',
        letterCount: glossary.letters.length,
        totalTerms,
      },
    });
  }
  for (const letter of glossary.letters) {
    paths.push({
      params: {slug: letter.slug},
      props: {page: letter, sidebar: glossary.sidebar, kind: 'letter'},
    });
  }
  return paths;
}

const {page, sidebar, kind, letterCount = 0, totalTerms = 0} = Astro.props;
const {navItems, brandHref, brandLabel, ecosystemConfigJson} = getPortalContext();
const sidebarItems = sidebar.map((item) => ({...item, active: item.slug === page.slug}));
const isIntro = kind === 'intro';
---

<PortalLayout
  title={isIntro ? 'Глоссарий IT Universe' : `${page.title} — Глоссарий IT Universe`}
  description={
    isIntro
      ? 'Справочник IT-терминов, понятий и аббревиатур — поиск и алфавитные разделы от 0 до Z.'
      : page.description || 'Справочник терминов Вселенная IT'
  }
  brandLabel={brandLabel}
  brandHref={brandHref}
  navItems={navItems}
  hasSidebar={true}
  contentWide={isIntro}
  ecosystemConfigJson={ecosystemConfigJson}
>
  <PortalSidebar slot="sidebar" title="Алфавит" items={sidebarItems} />

  <header class="portal-hero">
    <h1>{isIntro ? 'Глоссарий' : page.title}</h1>
    <p>
      {isIntro
        ? 'Точные определения IT-терминов — от аббревиатур до жаргона. Найдите слово или откройте нужную букву.'
        : page.description}
    </p>
  </header>

  {
    isIntro ? (
      <>
        <GlossarySearch termCount={totalTerms} letterCount={letterCount} />
        <article class="article-body" set:html={page.introHtml} />
      </>
    ) : (
      <>
        {page.terms.length > 0 ? (
          <nav aria-label="Термины на странице">
            <ul class="term-toc">
              {page.terms.map((term) => (
                <li>
                  <a href={`#${term.anchor}`}>{term.title}</a>
                </li>
              ))}
            </ul>
          </nav>
        ) : null}
        {page.introHtml ? <article class="article-body" set:html={page.introHtml} /> : null}
        <div class="term-index">
          {page.terms.map((term) => (
            <section class="term-entry" id={term.anchor}>
              <h2>
                <a href={`#${term.anchor}`}>{term.title}</a>
              </h2>
              <article class="article-body" set:html={term.html} />
            </section>
          ))}
        </div>
      </>
    )
  }

</PortalLayout>
